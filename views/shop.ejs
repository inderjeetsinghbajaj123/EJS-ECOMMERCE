<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop</title>
  <link rel="stylesheet" href="/styles/style.css">
</head>

<body class="shop-body">

  <nav class="navbar">
    <h1 class="logo">MyShop</h1>

    <div class="nav-right">
      <span class="user">
        👤 <%= user?.email || "User" %>
      </span>

      <a href="/owner/create" class="admin-btn">Admin</a>
      <a href="/products" class="admin-btn">Cart (<%= user.Cart ? user.Cart.length : 0 %>)</a>

      <form action="/user/logout" method="GET">
        <button class="logout-btn">Logout</button>
      </form>
    </div>
  </nav>

  <div class="shop-container">
    <h2 class="heading">Products</h2>

    <% if (error && error.length > 0) { %>
      <div class="alert error">
        <%= error[0] %>
      </div>
    <% } %>

    <div class="products">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>

          <div class="product-card"
               style="background-color: <%= product.panelcolor || '#f9fafb' %>; color: <%= product.textcolor || '#111827' %>;">
            
            <div style="background-color: <%= product.bgcolor || 'transparent' %>; padding:5px; border-radius:6px;">
              <img src="<%= product.image || 'https://via.placeholder.com/150' %>" class="product-img" />
            </div>

            <h3><%= product.name %></h3>
            <p class="price">₹ <%= product.price %></p>

            <form action="/products/add" method="POST">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <button class="cart-btn">Add to Cart</button>
            </form>
          </div>

        <% }) %>
      <% } else { %>
        <p>No products available</p>
      <% } %>
    </div>
  </div>

</body>
</html>